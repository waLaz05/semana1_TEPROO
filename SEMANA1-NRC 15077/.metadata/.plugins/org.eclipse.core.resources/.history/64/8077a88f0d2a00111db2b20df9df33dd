	ArregloEstudiante ae=new ArregloEstudiante();
	protected void do_btnNewButton_actionPerformed(ActionEvent e) {
		txtS.setText("");
		Listado();
		Imprimir("La cantidad de estudiantes es: "+ae.Tamaño());
		Imprimir("El promedio general es: "+ae.PromedioGeneral());
	}
	void Imprimir(String s) {
		txtS.append(s+"\n");
	}
	void Listado() {
		Imprimir("Código\tNombre\tNota 1\tNota 2\tPromedio");
		for (int i = 0; i < ae.Tamaño(); i++) {
			Imprimir(""+ae.Obtener(i).getCod()+"\t"+ae.Obtener(i).getNom()
			+"\t"+ae.Obtener(i).getN1()+"\t"+ae.Obtener(i).getN2()+
			"\t"+ae.Obtener(i).Promedio());
		}
	}
	protected void do_btnNewButton_3_actionPerformed(ActionEvent e) {
		txtS.setText("");
		Estudiante es=ae.Buscar(Integer.parseInt(txtCod.getText()));
		if(es!=null) {
			Imprimir("Código\tNombre\tNota 1\tNota 2\tPromedio");	
			Imprimir(es.getCod()+"\t"+es.getNom()+"\t"+es.getN1()+
			"\t"+es.getN1()+"\t"+es.Promedio());
		}
		else JOptionPane.showMessageDialog(this,"No existe código");
	}
